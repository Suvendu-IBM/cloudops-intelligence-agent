{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.27/MicrosoftTeams.schema.json",
  "manifestVersion": "1.27",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "Suvendu Panda",
    "websiteUrl": "https://www.example.com",
    "privacyUrl": "https://www.example.com/privacy",
    "termsOfUseUrl": "https://www.example.com/termofuse"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
  "short": "CloudOps Intelligence",
  "full": "CloudOps Intelligence Copilot"
},
  "description": {
  "short": "Cloud cost optimization, risk analysis and executive governance reporting.",
  "full": "CloudOps Intelligence Copilot provides cloud cost optimization insights, risk assessments, and executive governance reports using MCP-powered cloud intelligence tools."
},
  "accentColor": "#FFFFFF",
  "supportsChannelFeatures": "tier1",
  "composeExtensions": [],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "declarativeAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": []
}